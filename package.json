{
  "name": "weblink-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.4.0",
  "scripts": {
    "dev": "turbo dev --filter=@weblink/web",
    "dev:web": "turbo dev --filter=@weblink/web",
    "dev:web:fresh": "turbo dev --filter=@weblink/web --force",
    "dev:tauri": "turbo dev --filter=@weblink/tauri",
    "dev:electron": "turbo dev --filter=@weblink/electron",
    "dev:legacy": "vite",
    "build": "turbo run build",
    "build:web": "turbo build --filter=@weblink/web",
    "build:web:gh": "VITE_BASE_PATH=/weblink/ turbo build --filter=@weblink/web",
    "build:tauri": "turbo build --filter=@weblink/tauri",
    "build:electron": "turbo build --filter=@weblink/electron",
    "build:kits": "turbo run build --filter='./kits/*'",
    "build:kit": "turbo run build:standalone",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{js,mjs,cjs,ts,vue,json,md,css}\"",
    "clean": "turbo run clean && rm -rf node_modules/.cache"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/splitpanes": "^2.2.6",
    "@vitejs/plugin-vue": "^6.0.5",
    "eslint": "^10.2.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^16.2.0",
    "prettier": "^3.8.3",
    "turbo": "^2.9.14",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.4",
    "vitest": "^4.1.4",
    "vue-tsc": "^3.2.6"
  }
}
