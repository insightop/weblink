{
  "name": "@weblink/flashkit",
  "version": "0.1.0",
  "exports": {
    ".": "./src/index.ts"
  },
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit -p tsconfig.app.json && vite build",
