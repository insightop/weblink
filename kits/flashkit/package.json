    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@weblink/ui-vue": "workspace:*",
    "naive-ui": "^2.44.1",
    "pino": "^10.3.1",
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@weblink/eslint-config": "workspace:*",
    "@weblink/tsconfig": "workspace:*",
    "@types/node": "^24.12.2",
    "@types/w3c-web-hid": "^1.0.6",
    "@types/w3c-web-usb": "^1.0.14",
    "@vitejs/plugin-vue": "^6.0.5",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vitest": "^4.1.4",
    "vue-tsc": "^3.2.6"
  }
