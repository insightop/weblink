{
  "name": "@weblink/webrtckit",
  "private": true,
  "version": "0.0.0",
  "exports": {
    ".": "./src/index.ts"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit -p tsconfig.app.json && vite build",
    "pages:build": "npm run deploy:worker && npm run build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit -p tsconfig.app.json",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "test": "vitest run",
    "pages:dev": "npm run build && wrangler pages dev ./dist --compatibility-date=2025-01-01",
    "deploy:worker": "wrangler deploy --config workers/room-signaling/wrangler.toml"
  },
  "dependencies": {
    "@weblink/tokens": "workspace:*",
    "@weblink/ui-vue": "workspace:*",
    "@weblink/utils": "workspace:*",
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@weblink/eslint-config": "workspace:*",
    "@weblink/tsconfig": "workspace:*",
    "@cloudflare/workers-types": "^4.20251125.0",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vitest": "^4.1.4",
    "vue-tsc": "^3.2.6",
    "wrangler": "^4.54.0"
  }
}
