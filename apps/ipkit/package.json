{
  "name": "@weblink/ipkit",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "浏览器内 HTTP / WebSocket / DoH 等网络协议调试台",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit -p tsconfig.app.json && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit -p tsconfig.app.json",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "test": "vitest run"
  },
  "dependencies": {
    "naive-ui": "^2.44.1",
    "pinia": "^2.3.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^22.13.10",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/eslint-config-typescript": "^14.4.0",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^9.22.0",
    "eslint-plugin-vue": "^10.0.0",
    "prettier": "^3.5.3",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.26.1",
    "vite": "^6.2.2",
    "vitest": "^3.0.8",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^2.2.8"
  }
}
