{
  "productName": "Weblink",
  "version": "0.1.0",
  "identifier": "com.insightop.weblink",
  "build": {
    "frontendDist": "../web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --filter @weblink/web dev",
    "beforeBuildCommand": "pnpm --filter @weblink/web build"
  },
  "app": {
    "windows": [
      {
        "title": "Weblink",
        "width": 1280,
        "height": 860,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
  }
}
